# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/agrosmart

# JWT Secret (any random long string)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long

# Cloudinary (for photo uploads) — free at cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OpenWeatherMap API — free at openweathermap.org
WEATHER_API_KEY=your_weather_api_key

# Google Gemini API — free at ai.google.dev
GEMINI_API_KEY=your_gemini_api_key

# Server port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
